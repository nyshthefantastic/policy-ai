APP_NAME=PolicyOps AI
APP_ENV=local
APP_VERSION=0.1.0

DATABASE_URL=postgresql+psycopg://policyops:policyops@localhost:5432/policyops
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=policyops
POSTGRES_USER=policyops
POSTGRES_PASSWORD=policyops

REDIS_URL=redis://localhost:6379/0

OPENAI_API_KEY=
CHAT_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

DEFAULT_TENANT_ID=acme
DEFAULT_RATE_LIMIT_PER_MINUTE=20

MIN_CONFIDENCE_THRESHOLD=0.55
RETRIEVAL_TOP_K=8